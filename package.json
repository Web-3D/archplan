{
  "name": "archplan",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "ArchPlan — standalone procedural building editor (Three.js / WebGPU). Floor-plan → 3D building. Dùng building-kit (threejs-modules/building) + threejs-modules.",
  "author": "NgQuan",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,css,html}\"",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/three": "^0.174.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.2.2",
    "vite-plugin-checker": "^0.13.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "lil-gui": "^0.21.0",
    "three": "^0.174.0"
  }
}
